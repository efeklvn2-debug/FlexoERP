DATABASE_URL="postgresql://postgres:password@localhost:5432/flexoprint_erp?schema=public"
# REQUIRED: JWT secret for signing tokens. Must be set in all environments.
JWT_SECRET="change-this-to-a-very-long-random-string"
# Optional: initial admin password for first-run seeding. Defaults to 'admin123' in dev.
# REQUIRED when NODE_ENV=production.
ADMIN_PASSWORD="change-this-too"
LOG_LEVEL="info"
PORT=3000
# Set to "production" to suppress stack traces in error responses.
NODE_ENV="development"
# CORS origin for API access. Defaults to http://localhost:5173 in dev.
CORS_ORIGIN="http://localhost:5173"
