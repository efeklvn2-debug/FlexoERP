generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator seed {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

model User {
  id           String         @id @default(cuid())
  username     String         @unique
  passwordHash String
  role         Role           @default(OPERATOR)
  isActive     Boolean        @default(true)
  archivedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt    DateTime       @updatedAt
  refreshTokens  RefreshToken[]
  receipts       Receipt[]
  userPermissions UserPermission[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Permission {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  module      String?
  createdAt   DateTime  @default(now())
  rolePermissions RolePermission[]
  userPermissions  UserPermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([role, permissionId])
  @@index([role])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  granted      Boolean    @default(true)
  createdAt    DateTime   @default(now())

  @@unique([userId, permissionId])
  @@index([userId])
}

model IdempotencyKey {
  id        String   @id
  response  Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model BlockedIp {
  id        String   @id
  blockedAt DateTime @default(now())
  reason    String
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}



model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @db.Decimal(12, 2)
  notes        String?
  dueDate      DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdById  String?
  items        OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  @@index([orderId])
}

enum MaterialCategory {
  PLAIN_ROLLS
  INK_SOLVENTS
  PACKAGING
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  INITIAL
}

model Material {
  id            String           @id @default(cuid())
  code          String           @unique
  name          String
  category      MaterialCategory
  subCategory   String?          // e.g., "25microns", "IPA", "Packing Bag"
  unitOfMeasure String           @default("pcs")
  minStock      Int              @default(0)
  costPrice     Decimal?         @db.Decimal(12, 2) // cost per unit
  packSize      Int?             @default(1)        // for packaging: packs per bundle
  drumSize      Int?             // for ink/solvents: liters per drum
  coreWeight    Decimal?         @db.Decimal(6, 2)  // for plain rolls: weight of core in kg
  totalStock    Decimal?         @db.Decimal(12, 2) // current stock level
  notes         String?          // for audit trail
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  stocks        Stock[]
  movements     StockMovement[]
  rolls         Roll[]
  poLineItems   POLineItem[]
  priceLists    PriceList[]
  materialIssues MaterialIssue[]
}

model Stock {
  id          String   @id @default(cuid())
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
    quantity    Float    @default(0)
    location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  movements   StockMovement[]

  @@unique([materialId, location])
  @@index([materialId])
}

model StockMovement {
  id          String       @id @default(cuid())
  materialId  String
  material    Material     @relation(fields: [materialId], references: [id])
  stockId     String?
  stock       Stock?       @relation(fields: [stockId], references: [id])
  type        MovementType
  quantity    Float
  reference   String?
  notes       String?
  createdAt   DateTime     @default(now())
  createdById String?

  @@index([materialId])
  @@index([createdAt])
}

enum RollStatus {
  AVAILABLE
  IN_PRODUCTION
  CONSUMED
  RETURNED
  WASTED
}

enum POStatus {
  PENDING
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id            String     @id @default(cuid())
  poNumber      String     @unique
  supplier      String
  supplierId    String?
  supplierRef   Supplier?  @relation(fields: [supplierId], references: [id])
  status       POStatus   @default(PENDING)
  expectedDate  DateTime?
  issuedDate   DateTime?
  receivedDate DateTime?
  notes         String?
  totalAmount  Decimal?   @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdById  String?
  items        POLineItem[]
  rolls        Roll[]
  supplierInvoices SupplierInvoice[]

  @@index([poNumber])
  @@index([status])
}

model POLineItem {
  id              String        @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  materialId       String
  material        Material      @relation(fields: [materialId], references: [id])
      quantity    Float           // number of rolls
  totalWeight     Decimal       @db.Decimal(10, 2) // total kg
  unitPrice       Decimal       @db.Decimal(12, 2) // price per kg
  receivedQty     Int           @default(0)
  rollWeights     Decimal[]     @db.Decimal(10, 2) // individual roll weights (for tracking)
  createdAt       DateTime      @default(now())

  @@index([purchaseOrderId])
}

model Roll {
  id             String     @id @default(cuid())
  rollNumber     String     @unique
  materialId     String
  material       Material   @relation(fields: [materialId], references: [id])
  purchaseOrderId String?
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  parentRollId   String?
  parentRoll     Roll?      @relation("RollParent", fields: [parentRollId], references: [id])
  childRolls     Roll[]     @relation("RollParent")
  weight         Decimal    @db.Decimal(10, 2)
  remainingWeight Decimal   @db.Decimal(10, 2)
  width         Decimal?   @db.Decimal(8, 2)
  length         Decimal?   @db.Decimal(8, 2)
  coreSize       String?
  status         RollStatus @default(AVAILABLE)
  receivedDate   DateTime?
  notes          String?
  replacementReceived Boolean  @default(false)
  disposedAt     DateTime?
  disposedById   String?
  disposalReason String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  productionJobs  PrintedRoll[]

  @@index([materialId])
  @@index([status])
  @@index([rollNumber])
  @@index([parentRollId])
}

model ProductionJob {
   id                  String   @id @default(cuid())
   jobNumber           String   @unique
   customerName        String?
   customerId          String?
   customer            Customer? @relation("CustomerProductionJobs", fields: [customerId], references: [id])
   status              String   @default("PENDING")
   startDate           DateTime?
   endDate             DateTime?
   machine             String
   wasteWeight         Decimal? @db.Decimal(10, 2)
   notes               String?
   parentRollIds       String[] 
    printedRollMapping  Json?    // JSON array mapping printedRollId to parentRollId
    rollConsumption     Json?    // { parentRollId: kg } — user-reported exact contribution for first printed roll
    rollWaste           Json?    // { parentRollId: wasteKg } — per-roll waste at job level
    materialOverride    String?  // Material subCategory override if different from order's original material
    
    // Job costing
    materialCost        Decimal? @default(0) @db.Decimal(12, 2)  // Snapshot at completion (raw parent roll material)
    consumablesCost     Decimal? @default(0) @db.Decimal(12, 2)  // Ink + IPA + Butanol at completion
    overheadCost        Decimal? @default(0) @db.Decimal(12, 2)  // Calculated from overhead rate
   
   createdAt           DateTime @default(now())
   updatedAt           DateTime @updatedAt
   printedRolls        PrintedRoll[]
   salesOrderId        String?  @unique // Reference to sales order for bidirectional navigation
   salesOrder          SalesOrder? @relation(fields: [salesOrderId], references: [id])
   materialIssues      MaterialIssue[]
 
   @@index([jobNumber])
   @@index([status])
   @@index([salesOrderId])
   @@index([customerId])
}

model PrintedRoll {
  id              String        @id @default(cuid())
  productionJobId String
  productionJob   ProductionJob @relation(fields: [productionJobId], references: [id], onDelete: Cascade)
  rollId          String
  roll            Roll          @relation(fields: [rollId], references: [id])
  weightUsed      Decimal       @db.Decimal(10, 2)
  wasteWeight     Decimal?      @db.Decimal(10, 2)
  status          String        @default("IN_STOCK") // IN_STOCK, PICKED_UP, RETURNED
  isCombination   Boolean       @default(false)      // True if made from multiple parent rolls
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  pickedUpAt      DateTime?     // Timestamp when picked up
  returnedQty     Decimal?      @db.Decimal(10, 2)   // Quantity returned by customer
  returnReason    String?       // Defective, Wrong spec, Customer request, Other
  returnedAt      DateTime?     // Timestamp when returned
  refundMethod    String?       // NONE, CREDIT_NOTE, CASH_REFUND (informational only)
  returnCondition String?       // SCRAP, RETURN_TO_SUPPLIER
  createdAt       DateTime      @default(now())

  @@unique([productionJobId, rollId])
  @@index([rollId])
  @@index([status])
  @@index([customerId])
}

// ============================================================================
// INK COLORS (managed in Settings, used across app)
// ============================================================================

model InkColor {
  id        String   @id @default(cuid())
  name      String   @unique       // Customer-facing name, e.g. "RoyalBlue"
  mapping    String   @unique       // Material subCategory, e.g. "RoyalBlue-Ink"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Settings {
  id                    String   @id @default("default")
  coreWeight            Decimal  @default(0.7) @db.Decimal(5, 2)   // kg per plastic core
  rollWeight            Decimal  @default(15) @db.Decimal(5, 2)    // kg per roll
  inkConsumptionRate    Decimal  @default(0.7) @db.Decimal(5, 2)  // kg ink per kg printed
  ipaConsumptionRate   Decimal  @default(0.1) @db.Decimal(5, 2)   // L IPA per kg printed
  butanolConsumptionRate Decimal @default(0.1) @db.Decimal(5, 2) // L Butanol per kg printed
  inkCostPerKg          Decimal  @default(500) @db.Decimal(10, 2) // Cost per kg of ink/solvent mix
  coreDepositValue     Decimal  @default(150) @db.Decimal(10, 2) // Naira per core
  overheadRatePerKg    Decimal  @default(0) @db.Decimal(10, 2)    // Overhead rate per kg (Naira)
  walkInCustomerId     String?  // Default walk-in customer ID
  vatRate               Decimal  @default(7.5) @db.Decimal(4, 2)  // Nigerian VAT rate (%)
  businessTin          String?  // Business Tax Identification Number (optional)
  businessAddress      String?  // Business address for invoices
  invoiceCompanyName   String?  // Customizable company name on invoice PDF
  invoiceLogoUrl       String?  // Logo URL for invoice PDF
  invoicePrimaryColor  String?  // Primary color hex for invoice (default #1e3a5f)
  invoiceAccentColor   String?  // Accent color hex for invoice (default #dc2626)
  invoiceFooter        String?  // Custom footer text on invoice PDF
  receiptCompanyName   String?  // Customizable company name on receipt print/PDF
  receiptLogoUrl       String?  // Logo URL/data-URI for receipt print/PDF
  receiptFooter        String?  // Custom footer text on receipt print/PDF
  updatedAt            DateTime @updatedAt
}

// ============================================================================
// OVERHEAD RATE HISTORY
// ============================================================================

model OverheadRateHistory {
  id          String   @id @default(cuid())
  month       String   // YYYY-MM format
  ratePerKg   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  createdBy   String?
  
  @@unique([month])
}

// ============================================================================
// MATERIAL ISSUE (for job costing)
// ============================================================================

model MaterialIssue {
  id          String   @id @default(cuid())
  jobId       String
  job         ProductionJob @relation(fields: [jobId], references: [id])
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  quantityKg  Decimal  @db.Decimal(12, 2)
  unitCost    Decimal  @db.Decimal(12, 2)
  totalCost   Decimal  @db.Decimal(12, 2)
  issuedAt    DateTime @default(now())
  
  @@index([jobId])
}

// ============================================================================
// SUPPLIERS
// ============================================================================

model Supplier {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  email     String?
  phone     String?
  address   String?
  notes     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  purchaseOrders PurchaseOrder[]
  invoices       SupplierInvoice[]

  @@index([name])
  @@index([code])
}

// ============================================================================
// SUPPLIER INVOICES (Accounts Payable)
// ============================================================================

enum SupplierInvoiceStatus {
  PENDING
  PARTIAL
  PAID
}

model SupplierInvoice {
  id              String              @id @default(cuid())
  poId            String
  po              PurchaseOrder      @relation(fields: [poId], references: [id])
  supplierId      String
  supplier        Supplier           @relation(fields: [supplierId], references: [id])
  invoiceNumber   String             // Auto-generated: SI-YYYY-NNN
  date            DateTime           @default(now())
  dueDate         DateTime?
  amount          Decimal            @db.Decimal(12, 2)
  amountPaid      Decimal            @default(0) @db.Decimal(12, 2)
  status          SupplierInvoiceStatus @default(PENDING)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  payments        PaymentMade[]
  
  @@unique([invoiceNumber])
  @@index([supplierId])
}

model PaymentMade {
  id                  String          @id @default(cuid())
  supplierInvoiceId   String
  supplierInvoice     SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id])
  amount              Decimal         @db.Decimal(12, 2)
  date                DateTime        @default(now())
  paymentMethod       String          @default("Cash") // Cash or Bank Transfer
  reference           String?         // Cheque number, transfer ref, etc.
  notes               String?
  createdAt           DateTime        @default(now())
  
  @@index([supplierInvoiceId])
}

// ============================================================================
// FINANCE MODULE
// ============================================================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  COGS
}

model Account {
  id            String      @id @default(cuid())
  code          String      @unique  // e.g., "1000", "1100", "4000"
  name          String      @unique  // e.g., "Cash", "Accounts Receivable"
  type          AccountType
  parentId      String?
  parent        Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]   @relation("AccountHierarchy")
  isVatEnabled  Boolean     @default(false)  // For VAT tracking accounts
  isActive      Boolean     @default(true)
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  journalLines  JournalLine[]
  openingBalance Decimal    @default(0) @db.Decimal(15, 2)  // Opening balance for new accounts

  @@index([code])
  @@index([type])
  @@index([parentId])
}

enum SourceModule {
  SALES
  PROCUREMENT
  PRODUCTION
  EXPENSE
  INCOME
  PAYMENT
  ADJUSTMENT
  OPENING
}

model JournalEntry {
  id            String      @id @default(cuid())
  entryNumber   String      @unique  // Auto-generated: JE-2026-0001
  date          DateTime    @default(now())
  description   String
  sourceModule  SourceModule
  sourceId      String?     // ID of the triggering transaction
  reference     String?     // External reference (invoice #, receipt #)
  postedById    String?
  postedAt      DateTime    @default(now())
  isPosted      Boolean     @default(true)  // Always true for auto-posted entries
  lines        JournalLine[]

  @@index([entryNumber])
  @@index([date])
  @@index([sourceModule, sourceId])
  @@index([postedById])
}

model JournalLine {
  id              String      @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account     @relation(fields: [accountId], references: [id])
  debit           Decimal     @default(0) @db.Decimal(15, 2)
  credit          Decimal     @default(0) @db.Decimal(15, 2)
  memo            String?

  @@index([journalEntryId])
  @@index([accountId])
}

model PriceList {
  id            String    @id @default(cuid())
  materialId    String
  material      Material  @relation(fields: [materialId], references: [id])
  pricePerKg    Decimal?  @db.Decimal(12, 2)  // For PLAIN_ROLLS
  pricePerPack  Decimal?  @db.Decimal(12, 2)  // For PACKAGING (price per pack)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())

  @@unique([materialId, effectiveFrom])
  @@index([materialId])
}

model Transaction {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  date        DateTime @default(now())
  type        String   // PICKUP, PAYMENT, CORE_DEPOSIT
  amount      Decimal? @db.Decimal(10, 2) // For PAYMENT, CORE_DEPOSIT
  notes       String?
  printedRollIds String[] @default([]) // For PICKUP - links to printed rolls
  packingBags Decimal?  @default(0) @db.Decimal(15, 2) // For PICKUP
  amountPaid  Decimal? @db.Decimal(10, 2) // For PICKUP - amount paid at pickup
  createdAt   DateTime @default(now())

  @@index([customerId])
  @@index([date])
  @@index([type])
}

// ============================================================================
// MTO (MAKE-TO-ORDER) MODULE
// ============================================================================

enum DeliveryMethod {
  PICKUP
  SHIPPING
}

enum MTOOrderStatus {
  PENDING           // Just created, awaiting approval
  APPROVED         // Approved, ready for planning
  MRP_PENDING      // Awaiting material availability
  IN_PRODUCTION    // Production started
  READY            // Completed, ready for pickup
  PICKED_UP        // Customer collected goods
  COMPLETED        // Fully paid and closed
  CANCELLED        // Order cancelled
}

enum MTOPaymentStatus {
  PENDING_PAYMENT
  PARTIAL_DEPOSIT
  DEPOSIT_COMPLETE
  PARTIAL_PAYMENT
  FULLY_PAID
  OVERPAID
}

enum MTATransactionType {
  DEPOSIT
  PAYMENT
  CORE_BUYBACK
  CORE_CREDIT_APPLIED
  DEPOSIT_APPLIED
  REFUND
}

enum MTAPaymentMethod {
  CASH
  BANK_TRANSFER
}

enum MTAInvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum MTAPaymentType {
  CASH
  CREDIT
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  email     String?
  phone     String?
  address   String?
  colors    String[]  @default([])
  notes     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  // Payment Profile
  paymentType           MTAPaymentType @default(CREDIT)
  creditLimit           Decimal         @default(0) @db.Decimal(15, 2)
  depositPercentDefault Decimal         @default(0) @db.Decimal(5, 2)
  paymentTermsDays      Int             @default(0)  // 0 = at pickup, 7/15/30 = credit
  
  // Notification Preferences
  notifyEmail           Boolean         @default(true)
  notifyWhatsApp        Boolean         @default(true)
  
  // Relations
  orders               Order[]
  transactions         Transaction[]
  printedRolls         PrintedRoll[]
  salesOrders          SalesOrder[]
  paymentTransactions   PaymentTransaction[]
  invoices             Invoice[]
   coreBuybacks          CoreBuyback[]
   productionJobOrders   ProductionJob[] @relation("CustomerProductionJobs")
}

model SalesOrder {
  id                    String           @id @default(cuid())
  orderNumber           String           @unique  // SO-2026-0001
  customerId            String
  customer              Customer         @relation(fields: [customerId], references: [id])
  
  // Order Details
  specsJson             Json             // { width, color, material, etc. }
  quantityOrdered       Decimal          @db.Decimal(10, 2)
  quantityProduced      Decimal?         @db.Decimal(10, 2)  // Set after production completes
  quantityDelivered     Decimal          @default(0) @db.Decimal(10, 2)
  unitPrice             Decimal          @db.Decimal(15, 2)
  totalAmount           Decimal          @db.Decimal(15, 2)
  
  // Delivery
  deliveryMethod        DeliveryMethod   @default(PICKUP)
  shippingAddress       String?
  expectedDeliveryDate  DateTime?
  // Payment Tracking
  depositRequired       Decimal          @default(0) @db.Decimal(15, 2)
  depositPaid          Decimal          @default(0) @db.Decimal(15, 2)
  balancePaid          Decimal          @default(0) @db.Decimal(15, 2)
  totalPaid            Decimal          @default(0) @db.Decimal(15, 2)
  paymentStatus         MTOPaymentStatus @default(PENDING_PAYMENT)
  
  // Packing Bags Tracking
  packingBagsQuantity  Decimal          @default(0) @db.Decimal(15, 2)
  packingBagsAmount    Decimal          @default(0) @db.Decimal(15, 2)
  
  // Status (State Machine)
  status                MTOOrderStatus  @default(PENDING)
  
  // Production Link - Reference only (actual FK is on ProductionJob side)
  productionJobId       String?
  productionJob         ProductionJob?
  
  // Timestamps
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  approvedAt            DateTime?
  cancelledAt           DateTime?
  completedAt           DateTime?
  
  // Soft delete
  isDeleted             Boolean         @default(false)
  
  // Relations
  payments              PaymentTransaction[]
  invoices              Invoice[]
  
  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
}

model PaymentTransaction {
  id                    String             @id @default(cuid())
  salesOrderId          String?
  salesOrder            SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  customerId            String?
  customer              Customer?           @relation(fields: [customerId], references: [id])
  
  transactionType       MTATransactionType
  paymentMethod         MTAPaymentMethod
  paymentCategory       String?            // ROLL, BAG, BOTH
  amount                Decimal            @db.Decimal(15, 2)
  referenceNumber       String?
  notes                 String?
  
  // For core buyback (random seller)
  sellerName            String?   // if no customer (random person)
  coresQuantity         Int?      // for core buyback
  
  // Tracking
  receivedById          String?
  receivedAt            DateTime  @default(now())
  createdAt             DateTime  @default(now())
  
  receipts              Receipt[]

  @@index([salesOrderId])
  @@index([customerId])
  @@index([receivedAt])
  @@index([transactionType])
}

// ============================================================================
// RECEIPTS
// ============================================================================

model Receipt {
  id                    String   @id @default(cuid())
  receiptNumber         String   @unique  // REC-YYYY-NNNN
  paymentTransactionId  String
  paymentTransaction    PaymentTransaction @relation(fields: [paymentTransactionId], references: [id])
  customerName          String
  amount                Decimal  @db.Decimal(15, 2)
  paymentMethod         String
  referenceNumber       String?
  generatedById         String
  generatedBy           User     @relation(fields: [generatedById], references: [id])
  generatedAt           DateTime @default(now())

  @@index([receiptNumber])
  @@index([paymentTransactionId])
  @@index([generatedAt])
}

model Invoice {
  id                    String           @id @default(cuid())
  invoiceNumber         String           @unique  // INV-2026-0001
  salesOrderId          String
  salesOrder            SalesOrder      @relation(fields: [salesOrderId], references: [id])
  customerId            String
  customer              Customer        @relation(fields: [customerId], references: [id])
  
  // Line Items
  quantityDelivered     Decimal          @db.Decimal(10, 2)
  unitPrice             Decimal          @db.Decimal(15, 2)
  subtotal              Decimal          @db.Decimal(15, 2)
  vatAmount             Decimal          @default(0) @db.Decimal(15, 2)
  totalAmount           Decimal          @db.Decimal(15, 2)
  
  // Adjustments
  depositApplied        Decimal          @default(0) @db.Decimal(15, 2)
  previousPayments      Decimal          @default(0) @db.Decimal(15, 2)
  balanceDue            Decimal          @db.Decimal(15, 2)
  

  
  // Packing Bags Line Items
  packingBagsQuantity  Decimal          @default(0) @db.Decimal(15, 2)
  packingBagsUnitPrice Decimal         @db.Decimal(15, 2)
  packingBagsSubtotal  Decimal         @db.Decimal(15, 2)
  packingBagsPaid      Decimal         @default(0) @db.Decimal(15, 2)
  
  // Status
  status                MTAInvoiceStatus  @default(DRAFT)
  issuedAt              DateTime?
  dueDate               DateTime?
  paidAt                DateTime?
  
  // Amount tracking (computed from payments, but stored for quick access)
  amountPaid           Decimal          @default(0) @db.Decimal(15, 2)
  
  createdAt             DateTime        @default(now())
  
  payments              PaymentReceived[]
  
  @@index([invoiceNumber])
  @@index([salesOrderId])
  @@index([customerId])
  @@index([status])
}

// ============================================================================
// PAYMENTS RECEIVED (Accounts Receivable)
// ============================================================================

model PaymentReceived {
  id              String      @id @default(cuid())
  invoiceId       String
  invoice        Invoice    @relation(fields: [invoiceId], references: [id])
  amount          Decimal    @db.Decimal(12, 2)
  date            DateTime   @default(now())
  reference       String?    // Receipt number, transfer ref, etc.
  notes           String?
  paymentMethod   String?    // Cash or Bank Transfer
  createdAt       DateTime   @default(now())
  
  @@index([invoiceId])
}

model CoreBuyback {
  id                    String    @id @default(cuid())
  date                  DateTime  @default(now())
  
  // Who sold the cores
  customerId            String?
  customer              Customer? @relation(fields: [customerId], references: [id])
  sellerName            String?   // if random person (no customer account)
  
  // Core details
  coresQuantity         Int
  ratePerCore           Decimal   @db.Decimal(10, 2)
  totalValue            Decimal   @db.Decimal(15, 2)
  
  // How handled
  transactionType       MTATransactionType @default(CORE_BUYBACK)
  paymentMethod         MTAPaymentMethod
  paidAmount            Decimal   @default(0) @db.Decimal(15, 2)  // Cash paid (if random seller)
  
  // Tracking
  recordedById          String?
  notes                 String?
  
  createdAt             DateTime  @default(now())
  
  @@index([customerId])
  @@index([date])
}
